# Environment variables for the Enterprise GenAI Platform — Backend
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Enterprise GenAI Platform"
APP_VERSION="0.1.0"
ENVIRONMENT=development   # development | staging | production
DEBUG=true

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=genai_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=genai_platform

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text         # json | text (use json in production)
# LOG_FILE_PATH=        # Optional: /var/log/genai-platform/app.log

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------------------------
# Security (change ALL values before deploying to production)
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_MANAGER
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
